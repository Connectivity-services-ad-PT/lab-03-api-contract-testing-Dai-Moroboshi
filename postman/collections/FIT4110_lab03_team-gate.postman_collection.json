    {
      "name": "03_Negative",
      "item": [
        {
          "name": "Check Access - Invalid Payload (Missing field)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "123e4567-e89b-12d3-a456-426614174002" }
