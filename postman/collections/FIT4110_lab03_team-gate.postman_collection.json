  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has status ok\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql(\"ok\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Check Access - Valid Card (Allow)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "123e4567-e89b-12d3-a456-426614174000" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": \"RFID-2026-123\",\n  \"gateId\": \"GATE-01\",\n  \"timestamp\": \"2026-06-03T08:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access/check",
              "host": ["{{baseUrl}}"],
              "path": ["access", "check"]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has ALLOW or DENY decision\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"decisionId\");",
                  "    pm.expect([\"ALLOW\", \"DENY\"]).to.include(jsonData.status);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Decision Details",
          "request": {
            "method": "GET",
